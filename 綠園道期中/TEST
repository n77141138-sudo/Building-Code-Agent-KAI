<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>台南南鐵綠園道 - 民意分析與參與平台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap');
        body { font-family: 'Noto Sans TC', sans-serif; scroll-behavior: smooth; }
        .gradient-bg { background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%); }
        .card-shadow { box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <!-- 導航欄 -->
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center space-x-2">
                    <div class="w-8 h-8 bg-emerald-500 rounded-full flex items-center justify-center text-white font-bold">南</div>
                    <span class="text-xl font-bold tracking-tight">南鐵綠園道 <span class="text-emerald-600">Vision</span></span>
                </div>
                <div class="hidden md:flex space-x-8 text-sm font-medium">
                    <a href="#overview" class="hover:text-emerald-600 transition">計畫概述</a>
                    <a href="#analysis" class="hover:text-emerald-600 transition">民意分析</a>
                    <a href="#controversy" class="hover:text-emerald-600 transition">關鍵爭議</a>
                    <a href="#participation" class="bg-emerald-600 text-white px-4 py-2 rounded-full hover:bg-emerald-700 transition">立即發聲</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- 英雄區 -->
    <header class="relative py-20 gradient-bg text-white overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="md:w-2/3">
                <h1 class="text-4xl md:text-6xl font-extrabold mb-6">縫合城市裂痕，<br>定義下一代的台南風景。</h1>
                <p class="text-lg md:text-xl opacity-90 mb-10 leading-relaxed">
                    全長 8.23 公里的鐵路地下化騰空廊道，是走入歷史的舊鐵軌，還是接軌未來的綠色動脈？我們透過大數據分析與公民參與，彙整最真實的市民心聲。
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="#analysis" class="bg-white text-emerald-700 px-8 py-3 rounded-xl font-bold hover:bg-gray-100 transition shadow-lg">查看民調結果</a>
                    <a href="#participation" class="bg-emerald-900/30 backdrop-blur-sm border border-white/30 px-8 py-3 rounded-xl font-bold hover:bg-white/10 transition">參與工作坊報名</a>
                </div>
            </div>
        </div>
        <!-- 裝飾元素 -->
        <div class="absolute right-0 bottom-0 opacity-20 transform translate-x-1/4 translate-y-1/4">
            <svg width="600" height="600" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                <path fill="#FFFFFF" d="M44.7,-76.4C58.1,-69.2,69.2,-58.1,76.4,-44.7C83.7,-31.3,87,-15.7,85.8,-0.7C84.6,14.2,78.8,28.4,70.5,40.8C62.1,53.2,51.2,63.8,38.3,71.2C25.4,78.5,10.6,82.6,-4.1,89.7C-18.8,96.8,-33.4,106.9,-46.3,103.5C-59.2,100,-70.4,83,-78,67.7C-85.6,52.4,-89.6,38.8,-92.4,25.1C-95.2,11.4,-96.8,-2.4,-94.1,-15.5C-91.4,-28.6,-84.4,-41.1,-74.6,-51.7C-64.8,-62.3,-52.1,-71,-38.7,-78.1C-25.3,-85.2,-12.7,-90.7,1,-92.5C14.7,-94.3,29.4,-92.4,44.7,-76.4Z" transform="translate(100 100)" />
            </svg>
        </div>
    </header>

    <!-- 數據概覽區 -->
    <section id="analysis" class="py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold mb-4 text-gray-900">民意趨勢分析報告</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">彙整近期 15,000+ 份市民問卷與 20 場基層座談會意見，呈現大眾對綠園道規劃的最直接期望。</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- 圓餅圖：規劃優先序 -->
            <div class="bg-white p-8 rounded-3xl card-shadow border border-gray-100">
                <h3 class="text-xl font-bold mb-6 flex items-center">
                    <span class="w-2 h-6 bg-emerald-500 rounded-full mr-3"></span>
                    市民最關注的規劃重點 (權重分佈)
                </h3>
                <canvas id="priorityChart" class="max-h-80"></canvas>
            </div>

            <!-- 長條圖：分段支持度 -->
            <div class="bg-white p-8 rounded-3xl card-shadow border border-gray-100">
                <h3 class="text-xl font-bold mb-6 flex items-center">
                    <span class="w-2 h-6 bg-blue-500 rounded-full mr-3"></span>
                    各路段規劃方案滿意度
                </h3>
                <canvas id="sectionChart" class="max-h-80"></canvas>
            </div>
        </div>

        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
            <div class="bg-emerald-50 p-6 rounded-2xl">
                <div class="text-3xl font-black text-emerald-700 mb-2">72%</div>
                <div class="text-sm font-medium text-emerald-600">支持大幅減少車道寬度<br>優先保留人行與綠帶</div>
            </div>
            <div class="bg-blue-50 p-6 rounded-2xl">
                <div class="text-3xl font-black text-blue-700 mb-2">85%</div>
                <div class="text-sm font-medium text-blue-600">希望保留鐵軌與轉車台遺構<br>並與景觀融合展示</div>
            </div>
            <div class="bg-orange-50 p-6 rounded-2xl">
                <div class="text-3xl font-black text-orange-700 mb-2">64%</div>
                <div class="text-sm font-medium text-orange-600">擔憂學區周邊(聖功、開元)<br>接送交通動線問題</div>
            </div>
        </div>
    </section>

    <!-- 關鍵爭議點 -->
    <section id="controversy" class="py-20 bg-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row items-end justify-between mb-12">
                <div class="md:w-1/2">
                    <h2 class="text-3xl font-bold mb-4">目前的設計挑戰與爭議</h2>
                    <p class="text-gray-600">在專家理想與在地生活之間，我們發現了三個需要深度溝通的關鍵點。</p>
                </div>
                <div class="mt-4 md:mt-0">
                    <span class="text-sm text-gray-500 font-medium italic">* 更新日期：2024年4月24日</span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- 爭議一 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition group">
                    <div class="h-48 bg-gray-200 relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?auto=format&fit=crop&q=80&w=800" alt="交通示意圖" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                        <div class="absolute top-4 left-4 bg-red-500 text-white text-xs px-3 py-1 rounded-full font-bold">高爭議</div>
                    </div>
                    <div class="p-6">
                        <h4 class="text-lg font-bold mb-3">車道配置：人本 vs 效率</h4>
                        <p class="text-gray-600 text-sm leading-relaxed mb-4">
                            許多里長與里民反應，若將路面全數改為步道或僅供單車，將導致周邊鄰里交通癱瘓。市府目前規劃「縮減車道」但民間團體要求「去車路化」。
                        </p>
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-bold text-gray-400">#交通縫合 #人本交通</span>
                            <button class="text-emerald-600 text-sm font-bold hover:underline">閱讀詳情 →</button>
                        </div>
                    </div>
                </div>

                <!-- 爭議二 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition group">
                    <div class="h-48 bg-gray-200 relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1590073242678-70ee3fc28e84?auto=format&fit=crop&q=80&w=800" alt="歷史遺構示意圖" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                        <div class="absolute top-4 left-4 bg-blue-500 text-white text-xs px-3 py-1 rounded-full font-bold">共識中</div>
                    </div>
                    <div class="p-6">
                        <h4 class="text-lg font-bold mb-3">20處遺構的原地保存</h4>
                        <p class="text-gray-600 text-sm leading-relaxed mb-4">
                            出土的大北門城垣、轉車台等遺構如何與現代景觀共存？文資界主張「原址展示」，但涉及工程難度與排水規劃。
                        </p>
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-bold text-gray-400">#古都文資 #現地保存</span>
                            <button class="text-emerald-600 text-sm font-bold hover:underline">閱讀詳情 →</button>
                        </div>
                    </div>
                </div>

                <!-- 爭議三 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition group">
                    <div class="h-48 bg-gray-200 relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1596464716127-f2a82984de30?auto=format&fit=crop&q=80&w=800" alt="校園安全示意圖" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                        <div class="absolute top-4 left-4 bg-orange-500 text-white text-xs px-3 py-1 rounded-full font-bold">待協商</div>
                    </div>
                    <div class="p-6">
                        <h4 class="text-lg font-bold mb-3">學區安全與接送動線</h4>
                        <p class="text-gray-600 text-sm leading-relaxed mb-4">
                            聖功女中、開元國小等沿線學校高度關注學生上下學安全。綠園道寬度如何消化接送車潮，並避免產生視線死角？
                        </p>
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-bold text-gray-400">#校園安全 #學區生活圈</span>
                            <button class="text-emerald-600 text-sm font-bold hover:underline">閱讀詳情 →</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 公民參與表單 -->
    <section id="participation" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="bg-emerald-900 rounded-[3rem] p-8 md:p-16 text-white flex flex-col lg:flex-row gap-12 items-center">
                <div class="lg:w-1/2">
                    <h2 class="text-3xl md:text-4xl font-bold mb-6">您的意見，<br>是規劃案最重要的藍圖。</h2>
                    <p class="text-emerald-100 mb-8 leading-relaxed">
                        我們正彙整「公民白皮書」，將直接呈報給工務局與鐵道局。不論您是沿線居民、單車愛好者或是文史愛好者，您的發聲都將改變台南的未來。
                    </p>
                    <ul class="space-y-4">
                        <li class="flex items-start">
                            <div class="bg-emerald-500/20 p-1 rounded-full mr-3">✅</div>
                            <span>參加 113年9月 Citizen Workshop</span>
                        </li>
                        <li class="flex items-start">
                            <div class="bg-emerald-500/20 p-1 rounded-full mr-3">✅</div>
                            <span>填寫 5.5 公里分段詳細建議問卷</span>
                        </li>
                    </ul>
                </div>

                <div class="lg:w-1/2 w-full bg-white rounded-3xl p-8 text-gray-800 shadow-2xl">
                    <form id="opinionForm" class="space-y-5">
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">居住區域</label>
                            <select class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 outline-none focus:ring-2 focus:ring-emerald-500 transition">
                                <option>東區</option>
                                <option>北區</option>
                                <option>永康區</option>
                                <option>仁德區</option>
                                <option>其他台南市民</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">您最希望看到的設施</label>
                            <div class="grid grid-cols-2 gap-3">
                                <label class="flex items-center p-3 border border-gray-200 rounded-xl cursor-pointer hover:bg-gray-50 transition">
                                    <input type="checkbox" class="mr-2 text-emerald-600"> 自行車專用道
                                </label>
                                <label class="flex items-center p-3 border border-gray-200 rounded-xl cursor-pointer hover:bg-gray-50 transition">
                                    <input type="checkbox" class="mr-2 text-emerald-600"> 景觀遺構展示區
                                </label>
                                <label class="flex items-center p-3 border border-gray-200 rounded-xl cursor-pointer hover:bg-gray-50 transition">
                                    <input type="checkbox" class="mr-2 text-emerald-600"> 大片草坪與樹林
                                </label>
                                <label class="flex items-center p-3 border border-gray-200 rounded-xl cursor-pointer hover:bg-gray-50 transition">
                                    <input type="checkbox" class="mr-2 text-emerald-600"> 親子遊樂空間
                                </label>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">留下您的具體建言</label>
                            <textarea rows="3" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 outline-none focus:ring-2 focus:ring-emerald-500 transition" placeholder="例如：希望在勝利路交叉口加強人行安全規劃..."></textarea>
                        </div>
                        <button type="submit" class="w-full bg-emerald-600 text-white font-bold py-4 rounded-xl hover:bg-emerald-700 transition shadow-lg">提交意見</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- 底部資訊 -->
    <footer class="bg-gray-900 text-gray-400 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 border-t border-gray-800 pt-8">
            <div class="flex flex-col md:flex-row justify-between items-center">
                <div class="mb-4 md:mb-0">
                    <p class="text-sm font-medium">© 2024 台南南鐵綠園道民意研究小組 (模擬展示平台)</p>
                    <p class="text-xs mt-1">數據來源：台南市政府公聽會彙整、學術研究單位模擬問卷</p>
                </div>
                <div class="flex space-x-6 text-sm">
                    <a href="#" class="hover:text-white transition">隱私權政策</a>
                    <a href="#" class="hover:text-white transition">數據報告下載</a>
                    <a href="#" class="hover:text-white transition">聯繫我們</a>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // 渲染圖表
        window.onload = function() {
            // 圓餅圖
            const ctx1 = document.getElementById('priorityChart').getContext('2d');
            new Chart(ctx1, {
                type: 'doughnut',
                data: {
                    labels: ['生態綠化', '歷史文資', '交通機能', '休憩設施', '永續能源'],
                    datasets: [{
                        data: [40, 25, 15, 12, 8],
                        backgroundColor: ['#10b981', '#3b82f6', '#f59e0b', '#ef4444', '#8b5cf6'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });

            // 長條圖
            const ctx2 = document.getElementById('sectionChart').getContext('2d');
            new Chart(ctx2, {
                type: 'bar',
                data: {
                    labels: ['北段 (柴頭港溪-小東路)', '中段 (台南車站區)', '南段 (林森路-保仁路)'],
                    datasets: [
                        {
                            label: '方案滿意度 (%)',
                            data: [78, 62, 84],
                            backgroundColor: '#3b82f6',
                            borderRadius: 8
                        },
                        {
                            label: '期待值 (%)',
                            data: [85, 95, 88],
                            backgroundColor: '#e5e7eb',
                            borderRadius: 8
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom' }
                    },
                    scales: {
                        y: { beginAtZero: true, max: 100 }
                    }
                }
            });
        };

        // 表單提交處理 (模擬)
        document.getElementById('opinionForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const successMsg = document.createElement('div');
            successMsg.className = 'fixed bottom-10 right-10 bg-emerald-600 text-white px-6 py-4 rounded-2xl shadow-2xl z-50 animate-bounce';
            successMsg.innerHTML = '✨ 感謝您的發聲！意見已成功收集。';
            document.body.appendChild(successMsg);
            setTimeout(() => successMsg.remove(), 4000);
            this.reset();
        });
    </script>
</body>
</html>